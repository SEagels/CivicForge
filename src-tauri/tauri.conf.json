{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "CivicForge",
  "version": "0.1.0",
  "identifier": "local.civicforge.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "CivicForge",
        "width": 1280,
        "height": 820,
        "minWidth": 980,
        "minHeight": 680
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/icon.ico"]
  },
  "plugins": {
    "sql": {
      "preload": ["sqlite:civicforge.db"]
    }
  }
}
